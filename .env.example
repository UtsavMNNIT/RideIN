# =============================================================================
# RideFlow — local development environment variables
# Copy to `.env` (gitignored) and adjust as needed.
# Compose auto-loads `.env` from the project root.
# =============================================================================

# ---- PostgreSQL (superuser + per-service roles) ----
POSTGRES_DB=rideflow
POSTGRES_USER=rideflow
POSTGRES_PASSWORD=changeme_rideflow

RIDER_DB_PASSWORD=changeme_rider
DRIVER_DB_PASSWORD=changeme_driver
MATCHING_DB_PASSWORD=changeme_matching
PRICING_DB_PASSWORD=changeme_pricing
TRIP_DB_PASSWORD=changeme_trip
NOTIFICATION_DB_PASSWORD=changeme_notification
PAYMENT_DB_PASSWORD=changeme_payment

# ---- JWT / auth ----
# HS256 signing secrets + issuers for the rider and driver services. The
# api-gateway validates tokens against these, and the frontend edge middleware
# must use the SAME secrets (see frontend/.env.local.example). Values below are
# the dev defaults baked into docker-compose; override in any real environment.
RIDER_JWT_SECRET=dev-only-rider-service-secret-change-me-please-0123456789
DRIVER_JWT_SECRET=dev-only-driver-service-secret-change-me-please-0123456789
RIDER_JWT_ISSUER=rideflow-rider-service
DRIVER_JWT_ISSUER=rideflow-driver-service

# ---- Redis ----
# Two instances, two policies. Host ports differ; container ports are both 6379.
REDIS_GEO_HOST=redis-geo
REDIS_GEO_PORT=6379
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PORT=6379

# ---- Kafka ----
# Use INTERNAL from app containers; EXTERNAL from your host (kcat, etc.)
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
KAFKA_BOOTSTRAP_EXTERNAL=localhost:29092

# ---- Frontend / optional integrations ----
# The Next.js frontend has its own env file: copy frontend/.env.local.example
# → frontend/.env.local. Optional keys (Mapbox tile token, Twilio SMS 2FA,
# ZeroBounce email verification) live there; each degrades to demo mode if unset.
