# =============================================================================
# RideFlow — local development environment variables
# Copy to `.env` (gitignored) and adjust as needed.
# Compose auto-loads `.env` from the project root.
# =============================================================================

# ---- PostgreSQL (superuser + per-service roles) ----
POSTGRES_DB=rideflow
POSTGRES_USER=rideflow
POSTGRES_PASSWORD=changeme_rideflow

RIDER_DB_PASSWORD=changeme_rider
DRIVER_DB_PASSWORD=changeme_driver
MATCHING_DB_PASSWORD=changeme_matching
PRICING_DB_PASSWORD=changeme_pricing

# ---- Redis ----
# Two instances, two policies. Host ports differ; container ports are both 6379.
REDIS_GEO_HOST=redis-geo
REDIS_GEO_PORT=6379
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PORT=6379

# ---- Kafka ----
# Use INTERNAL from app containers; EXTERNAL from your host (kcat, etc.)
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
KAFKA_BOOTSTRAP_EXTERNAL=localhost:29092
