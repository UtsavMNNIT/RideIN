# =============================================================================
# RideFlow — root .gitignore (minimal; per-module .gitignore added in 1B)
# =============================================================================

# Secrets
.env
.env.local
*.pem
*.key

# IDE
.idea/
.vscode/
*.iml
.DS_Store

# Build outputs (filled in by per-module .gitignore in 1B)
**/build/
**/target/
**/node_modules/
**/.next/
**/dist/
**/out/

# ...but the hexagonal "output port" SOURCE packages live in `application/port/out/`
# and must never be treated as build output (the `**/out/` rule above would
# otherwise silently drop these interfaces from version control).
!**/application/port/out/
!**/application/port/out/**

# Logs
*.log
logs/

# Docker
.docker/

# Local override file
docker-compose.override.yml

# Docker tutorial sample (not part of this project)
welcome-to-docker/

# Stray image files at repo root (not project assets)
/*.jpg

# Local scratch / throwaway scripts (smoke tests, experiments)
scratchpad/

# TypeScript incremental build cache (regenerated on every build)
frontend/tsconfig.tsbuildinfo
