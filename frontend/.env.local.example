# =========================================================================
# RideFlow — frontend env (copy to .env.local; never commit the real file)
# =========================================================================

# REST: API Gateway. In local-dev the Next.js rewrite (next.config.ts) maps
# /api/gateway/* → this base, so the browser sees same-origin requests.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# WebSocket: notification-service direct in local-dev. In prod this routes
# through the gateway with WS upgrade enabled.
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8086

# Map tile provider. "osm" = OpenStreetMap (no key). "mapbox" requires a token.
NEXT_PUBLIC_MAP_PROVIDER=osm
# NEXT_PUBLIC_MAPBOX_TOKEN=

# Build metadata surfaced in the footer / about page.
NEXT_PUBLIC_APP_NAME=RideFlow
NEXT_PUBLIC_APP_VERSION=0.1.0

# Server-side email deliverability check (ZeroBounce). NOT NEXT_PUBLIC — this
# key must never reach the browser; it's read only by app/api/auth/verify-email.
# Get a key (free tier includes 100 credits): https://www.zerobounce.net/
# If unset, registration/login still work but the deliverability check is skipped.
EMAIL_VERIFY_API_KEY=

# SMS two-factor (Twilio). Server-only — these must never be NEXT_PUBLIC.
# Read only by app/api/auth/send-otp. If unset, 2FA runs in demo mode: the
# 6-digit code is shown on screen instead of being texted.
# Console: https://console.twilio.com  (trial accounts can only text verified numbers)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
